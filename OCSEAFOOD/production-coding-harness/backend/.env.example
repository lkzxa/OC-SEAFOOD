# ⚠️  SECURITY WARNING
# -------------------------------------------------------
# 1. NEVER commit a real .env file to version control.
#    This .env.example is the only file that should exist in git.
# 2. JWT_SECRET must be a cryptographically random string of at least 64 chars.
#    Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 3. Use strong, unique DATABASE_URL credentials in production.
# -------------------------------------------------------

PORT=5000
NODE_ENV=development
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
DATABASE_URL=postgresql://user:password@localhost:5432/ocseafood?schema=public

# Notification SMTP configurations
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
EMAIL_FROM=no-reply@ocseafood.com
EMAIL_TO_ADMIN=admin@ocseafood.com

# Telegram Bot configurations
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Zalo Notification configurations
ZALO_OA_ACCESS_TOKEN=your_zalo_oa_access_token_here
ZALO_USER_ID=your_zalo_user_id_here

# Worker settings
NOTIFICATION_WORKER_INTERVAL_MS=10000
MAX_NOTIFICATION_RETRIES=5

# Google OAuth 2.0 configurations (Admin Only)
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/login

